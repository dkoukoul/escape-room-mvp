{
  "name": "escape-room-mvp",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "NODE_ENV=development bun --watch src/server/index.ts",
    "dev:client": "NODE_ENV=development vite",
    "build": "vite build",
    "start": "concurrently \"bun run start:server\" \"bun run start:client\"",
    "start:server": "NODE_ENV=production bun src/server/index.ts",
    "start:client": "NODE_ENV=production vite",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test src/server",
    "test:client": "vitest run",
    "test:client:watch": "vitest",
    "test:client:coverage": "vitest run --coverage",
    "test:puzzles": "bun run e2e/puzzle-runner.ts"
  },
  "dependencies": {
    "@browserbasehq/sdk": "^2.7.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/winston": "^2.4.4",
    "chokidar": "^5.0.0",
    "ioredis": "^5.10.00",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "winston": "^3.19.0",
    "yaml": "^2.7.0",
    "zzfx": "^1.3.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/bun": "latest",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.2",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
